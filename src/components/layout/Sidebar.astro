---
import { config } from "@parseConfig"
import { Icon } from "astro-icon/components"

const navMenu = config.navigation
const socialLinks = config.social || []

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---

<aside class="">
  <nav
    class="flex flex-wrap items-center gap-x-6 gap-y-1 border-b border-border/50 py-4 md:mt-16 md:h-fit md:flex-col md:items-end md:border-r md:border-b-0 md:py-0 md:pr-8"
  >
    {
      navMenu.map((nav) => (
        <a
          href={nav.href}
          class:list={[
            "py-0.5 text-muted-foreground transition-colors duration-200 ease-out hover:text-foreground",
            isActive(nav.href) &&
              "font-medium text-foreground! underline decoration-muted-foreground/50 underline-offset-2 hover:decoration-muted-foreground",
          ]}
        >
          {nav.label}
        </a>
      ))
    }

    {socialLinks.length > 0 && (
      <div class="flex items-center gap-x-4 md:mt-4 md:flex-col md:items-end md:gap-y-2">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground transition-colors duration-200 ease-out hover:text-foreground"
            aria-label={social.label}
          >
            <Icon name={social.icon} size={18} />
          </a>
        ))}
      </div>
    )}
  </nav>
</aside>
